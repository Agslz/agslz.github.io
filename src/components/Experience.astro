---
import ExperienceItem from "./ExperienceItem.astro";
const EXPERIENCE = [
  {
    date: "Enero 2025 - Actual",
    title: "Desarrollador Java Backend",
    company: "MuniDigital",
    description:
      "Actualmente, soy Full Stack Developer, desarrollando soluciones escalables con Java, Spring, React y Backbone. Enfocado en backend y procesamiento de datos, gestiono bases de datos dockerizadas y desarrollo servicios en Spring sobre Tomcat. Trabajo con Scrum, organizando tareas en Jira y participando en dailys y sprints. Además, utilizo herramientas de IA (Cursor, Codex y agentes) para automatizar tareas y mejorar la productividad. Implemento y mantengo frontend en Backbone y Grunt, desarrollando micro frontends con React. Manejo autenticación y autorización con JWT, cookies y Google Workspace, optimizando seguridad y accesibilidad mediante gestión de sesiones y redireccionamientos.",
    link: "https://munidigital.tech/"
  },
  {
    date: "Agosto 2023 - Diciembre 2024",
    title: "Desarrollador Full Stack",
    company: "Municipalidad de Capital de Mendoza",
    description:
      "Trabajé como desarrollador Full Stack en el área de Desarrollo y Sistemas, aportando soluciones robustas y escalables con Java, Spring Boot, React y Node.js. Participé en aplicaciones web, móviles y sistemas empresariales, realizando mantenimiento de sistemas críticos, desarrollo de APIs e integración con servicios externos. Además, incorporé el uso de herramientas de IA (Cursor, Codex y agentes) para optimizar tareas de desarrollo y flujos de trabajo. Gestión de bases de datos con MySQL y MongoDB.",
    link: "https://ciudaddemendoza.gob.ar/",
  },
  {
    date: "Enero 2022 - Agosto 2023",
    title: "Maestro/Tutor Backend",
    company: "Egg Cooperation",
    description:
      "Ser tutor en la comunidad Egg me permitió fortalecer mis habilidades blandas y comprender la importancia de la cooperación y el trabajo en equipo. Como maestro en este bootcamp de programación, ayudé a los alumnos a superar dificultades en Java, Spring Boot, Spring MVC y principios de POO, así como en tecnologías frontend como HTML, CSS, JavaScript, Bootstrap y React.",
    link: "https://site.egg.live/es-ar/",
  }
];
---

<ol class="relative mt-16">
  {EXPERIENCE.map((experience) => (
    <li>
      <ExperienceItem {...experience} />
    </li>
  ))}
</ol>
